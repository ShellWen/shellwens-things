    <div class="footer md:footer-horizontal">
      <nav>
        <header class="footer-title">联系方式</header>
        <div class="grid grid-flow-col gap-4">
          <a href="https://github.com/ShellWen" target="_blank">
            <span class="sr-only">在 GitHub 上关注我：@ShellWen</span>
            <IconGithub class="size-6" />
          </a>
          <a href="https://x.com/realShellWen" target="_blank">
            <span class="sr-only">在 Twitter 上关注我：@realShellWen</span>
            <IconTwitter class="size-6" />
          </a>
          <a href="https://discordapp.com/users/686031289534513225" target="_blank">
            <span class="sr-only">在 Discord 上找到我：@ShellWen</span>
            <IconDiscord class="size-6" />
          </a>
          <a href="https://steamcommunity.com/id/shellwen/" target="_blank">
            <span class="sr-only">在 Steam 上和我一起玩：@ShellWen</span>
            <IconSteam class="size-6" />
          </a>
          <a href="mailto:me@shellwen.com" target="_blank">
            <span class="sr-only">给我发 E-mail: me@shellwen.com</span>
            <IconAlternateEmail class="size-6" />
          </a>
          <a href="https://qm.qq.com/q/cKzp5dduM0" target="_blank">
            <span class="sr-only">添加我 QQ 好友: 3590398766</span>
            <IconQq class="size-6" />
