---
import IconAlternateEmail from '~icons/material-symbols/alternate-email'
import IconRssFeed from '~icons/material-symbols/rss-feed'
import IconDiscord from '~icons/simple-icons/discord'
import IconGithub from '~icons/simple-icons/github'
import IconQq from '~icons/simple-icons/qq'
import IconSteam from '~icons/simple-icons/steam'
import IconTwitter from '~icons/simple-icons/twitter'

const today = new Date()
const year = today.getFullYear()
---

<div
  class="w-full bg-neutral p-(--page-padding) text-neutral-content"
  transition:name="footer"
  transition:animate="none"
>
