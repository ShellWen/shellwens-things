        >
      </nav>
      <nav>
        <header class="footer-title">Feed</header>
        <a href="/rss.xml">
          <span class="sr-only">RSS 订阅</span>
          <IconRssFeed class="size-6" />
        </a>
      </nav>
    </div>
    <div class="inline-block pt-4">
      <a href="https://note.glassfoxowo.com/" target="_blank" class="link no-underline">被驯服的狐狸玻狸🦊♥️🐻</a>
      {' | '}
