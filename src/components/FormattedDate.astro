---
import type { HTMLAttributes } from 'astro/types'

interface Props extends Omit<HTMLAttributes<'time'>, 'datetime'> {
  date: Date | string
}

const { date, ...timeProps } = Astro.props

const dateObj = typeof date === 'string' ? new Date(date) : date
---

<time datetime={dateObj.toISOString()} {...timeProps}>
  {
    dateObj.toLocaleDateString('zh-Hans-CN', {
      year: 'numeric',
      month: 'numeric',
      day: 'numeric',
    })
  }
</time>
